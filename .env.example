# ===============================================================
# SmartDrobe — Environment Variables Template
# ===============================================================
#
# ⚠️  SECURITY WARNING:
# 1. Copy this file to .env.local and fill in your values
# 2. NEVER commit .env.local to version control
# 3. NEVER share your API keys with anyone
# 4. If you accidentally expose keys, rotate them immediately
# 5. Use different keys for dev/staging/production
#
# 📖 For setup instructions, see: README.md
# ===============================================================

# ─── Supabase (Required) ────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ─── Google Gemini AI (Required) ────────────────────────────────────────────
# Get these from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# ─── Cloudinary — Image Storage (Required for uploads) ──────────────────────
# Get these from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ─── OpenWeatherMap (Optional — enables weather-aware recommendations) ───────
# Get a free key from: https://openweathermap.org/api
NEXT_PUBLIC_OPENWEATHER_API_KEY=your-openweathermap-api-key

# ─── Application Settings ────────────────────────────────────────────────────
# Default city for weather fallback (optional, defaults to London)
DEFAULT_CITY=London

# Node environment (set automatically by hosting platform)
# NODE_ENV=production

# ─── Development Only ─────────────────────────────────────────────────────────
# Uncomment for local development
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===============================================================
# 🔒 SECURITY REMINDERS:
# ===============================================================
# ✅ DO:
#   - Keep this file updated when adding new env vars
#   - Use placeholder values (like above)
#   - Document what each variable does
#   - Rotate keys regularly (every 90 days)
#   - Use different keys per environment
#
# ❌ DO NOT:
#   - Commit .env.local to git (already in .gitignore)
#   - Share your actual API keys
#   - Use production keys in development
#   - Hardcode secrets in your code
#   - Post keys in Slack/Discord/forums
# ===============================================================
